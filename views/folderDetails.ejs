<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%=folder.name%></title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <h1>File Uploader</h1>
    <% folder.files.map((file) => { %>
        <a href="/folder/<%=folder.id%>/file/<%=file.id%>"><div class="file"><%=file.name%></div></a>
    <% }) %>
    <a href="/folder/edit/<%=folder.id%>"><button>Edit</button></a>
    <form action="/folder/delete/<%=folder.id%>" method="POST"><button>Delete</button></form>
    <a href="/folder/<%=folder.id%>/file/upload"><button>Upload</button></a>
    <a href="/"><button>Back</button></a>
</body>
</html>