<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%=folder.name%></title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <h1>File Uploader</h1>
    <% folder.files.map((file) => { %>
        <div class="file"><%=file.name%></div>
    <% }) %>
    <a href="/folder/edit/<%=folder.id%>"><button class="form-b">Edit</button></a>
    <form action="/folder/delete/<%=folder.id%>" method="POST"><button class="form-b">Delete</button></form>
    <a href="/"><button class="form-b">Back</button></a>
</body>
</html>